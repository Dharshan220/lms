{
  "version": 2,
  "outputDirectory": "public",
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php@0.5.8"
    }
  ],
  "routes": [
    {
      "src": "/build/assets/(.*)",
      "dest": "/build/assets/$1"
    },
    {
      "src": "/favicon\\.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/robots\\.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.php"
    }
  ]
}
